{
  "entities": {
    "Performance": {
      "title": "Performance Report",
      "description": "Daily or weekly return data for the quant strategy.",
      "type": "object",
      "properties": {
        "date": { "type": "string", "format": "date", "description": "The date of the report." },
        "returnValue": { "type": "number", "description": "The percentage return (e.g., 2.5 for 2.5%)." },
        "type": { "type": "string", "enum": ["daily", "weekly"], "description": "The period type." },
        "description": { "type": "string", "description": "Optional notes or summary." },
        "imageUrl": { "type": "string", "description": "Optional chart or GIF URL." }
      },
      "required": ["date", "returnValue", "type"]
    },
    "BlogPost": {
      "title": "Blog Post",
      "description": "Market analysis or news updates.",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "The post title." },
        "content": { "type": "string", "description": "Markdown content." },
        "author": { "type": "string", "description": "The author's name." },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp." },
        "tags": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["title", "content", "author", "createdAt"]
    },
    "User": {
      "title": "User Profile",
      "description": "User account information and roles.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "user"] }
      },
      "required": ["uid", "email", "role"]
    }
  },
  "firestore": {
    "/performance/{reportId}": { "schema": "Performance", "description": "Quant strategy performance records." },
    "/blog/{postId}": { "schema": "BlogPost", "description": "Market analysis and news." },
    "/users/{userId}": { "schema": "User", "description": "User profiles and permissions." }
  }
}

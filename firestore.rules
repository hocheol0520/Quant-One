rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: performance
    // Fields:
    //   - date: string (YYYY-MM-DD)
    //   - returnValue: number
    //   - type: string ('daily', 'weekly')
    //   - description: string (optional)
    //   - imageUrl: string (optional)
    //
    // Collection: blog
    // Fields:
    //   - title: string
    //   - content: string
    //   - author: string
    //   - createdAt: string (ISO 8601)
    //   - tags: list of strings
    //
    // Collection: users
    // Fields:
    //   - uid: string
    //   - email: string
    //   - role: string ('admin', 'user')
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "hocheol05201@gmail.com" && request.auth.token.email_verified == true));
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidPerformance(data) {
      return data.date is string && 
             data.returnValue is number && 
             data.type in ['daily', 'weekly'];
    }

    function isValidBlog(data) {
      return data.title is string && data.title.size() > 0 &&
             data.content is string && data.content.size() > 0 &&
             data.author is string &&
             data.createdAt is string;
    }

    function isValidUser(data) {
      return data.uid is string && 
             data.email is string && 
             data.role in ['admin', 'user'];
    }

    // Rules
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isOwner(userId) && isValidUser(request.resource.data) && request.resource.data.role == 'user';
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /performance/{reportId} {
      allow read: if true; // Publicly readable for marketing
      allow write: if isAdmin() && isValidPerformance(request.resource.data);
    }

    match /blog/{postId} {
      allow read: if true; // Publicly readable
      allow write: if isAdmin() && isValidBlog(request.resource.data);
    }
  }
}
